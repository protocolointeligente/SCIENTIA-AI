NODE_ENV=development
PORT=3001

# Pooled (pgbouncer) — runtime
DATABASE_URL="postgres://user:password@pooler.host:6543/postgres?sslmode=require&pgbouncer=true"
# Direct (non-pooled) — migrations only
DIRECT_URL="postgres://user:password@db.host:5432/postgres?sslmode=require"

REDIS_URL="redis://localhost:6379"

# --- Auth (Supabase Auth replaces Clerk) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MERCADO_PAGO_ACCESS_TOKEN=

ELASTICSEARCH_URL="http://localhost:9200"
