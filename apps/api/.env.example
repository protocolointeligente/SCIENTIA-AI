NODE_ENV=development
PORT=3001

# ── Banco de dados (Supabase / Postgres) ─────────────────────────────────────
# Pooled (pgbouncer) — usado pelo Prisma Client em runtime
DATABASE_URL="postgres://user:password@pooler.host:6543/postgres?sslmode=require&pgbouncer=true"
# Direct (não-pooled) — usado pelo prisma migrate / prisma db push
DIRECT_URL="postgres://user:password@db.host:5432/postgres?sslmode=require"

# ── Autenticação (Supabase Auth) ──────────────────────────────────────────────
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ── Filas / Redis (Upstash) ───────────────────────────────────────────────────
REDIS_URL="rediss://default:<token>@<host>.upstash.io:6379"
KV_REST_API_URL=https://<host>.upstash.io
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ── IA ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# ── Pagamentos ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MERCADO_PAGO_ACCESS_TOKEN=
