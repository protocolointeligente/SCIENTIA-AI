# Pooled connection (pgbouncer) — used by Prisma Client at runtime
DATABASE_URL="postgres://user:password@pooler.host:6543/postgres?sslmode=require&pgbouncer=true"

# Direct (non-pooled) connection — used by prisma migrate / prisma db push
DIRECT_URL="postgres://user:password@db.host:5432/postgres?sslmode=require"
